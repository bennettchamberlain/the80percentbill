# Geocodio API for address → congressional district lookup
GEOCODIO_API_KEY=

# Gmail app password (optional)
EMAIL_PASSWORD=

# Supabase Postgres (if set, uses Supabase; otherwise SQLite)
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PORT=5432
