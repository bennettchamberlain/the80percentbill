# Geocodio API for address → congressional district lookup
GEOCODIO_API_KEY=

# Gmail app password (optional)
EMAIL_PASSWORD=

# Supabase Postgres (if set, uses Supabase; otherwise SQLite)
# For Railway: use pooler (IPv4) — get from Supabase → Connect → Session pooler
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PORT=5432
SUPABASE_USE_POOLER=true
